<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wanderlust — Find Your Perfect Stay</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    html,
    body {
      height: 100%;
      margin: 0;
    }

    .welcome-page {
      min-height: 100vh;
      background: linear-gradient(135deg, #6b0f1a 0%, #b5172c 50%, #dc3545 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
    }

    .welcome-card {
      max-width: 600px;
      width: 100%;
    }

    .brand-icon {
      font-size: 4rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 0.5rem;
    }

    .brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 4rem;
      font-weight: 550;
      color: #ffffff;
      letter-spacing: 10px;
    }

    .brand-tagline {
      font-size: 1.15rem;
      color: rgba(255, 255, 255, 0.85);
      font-weight: 400;
      line-height: 1.7;
      margin: 1.2rem 0 2.5rem;
    }

    .divider {
      width: 60px;
      height: 3px;
      background: rgba(255, 255, 255, 0.5);
      margin: 1rem auto;
      border-radius: 2px;
    }

    .btn-welcome-primary {
      background-color: #ffffff;
      color: #b5172c;
      border: 2px solid #ffffff;
      font-weight: 700;
      padding: 0.65rem 2rem;
      border-radius: 50px;
      font-size: 1rem;
      transition: all 0.25s ease;
    }

    .btn-welcome-primary:hover {
      background-color: transparent;
      color: #ffffff;
    }

    .btn-welcome-outline {
      background-color: transparent;
      color: #ffffff;
      border: 2px solid rgba(255, 255, 255, 0.7);
      font-weight: 600;
      padding: 0.65rem 2rem;
      border-radius: 50px;
      font-size: 1rem;
      transition: all 0.25s ease;
    }

    .btn-welcome-outline:hover {
      background-color: rgba(255, 255, 255, 0.15);
      color: #ffffff;
      border-color: #ffffff;
    }

    .btn-welcome-google {
      background-color: rgba(255, 255, 255, 0.12);
      color: #ffffff;
      border: 2px solid rgba(255, 255, 255, 0.4);
      font-weight: 500;
      padding: 0.6rem 1.8rem;
      border-radius: 50px;
      font-size: 0.95rem;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.25s ease;
    }

    .btn-welcome-google:hover {
      background-color: rgba(255, 255, 255, 0.22);
      border-color: rgba(255, 255, 255, 0.7);
      color: #ffffff;
    }

    .btn-welcome-ghost {
      background-color: transparent;
      color: rgba(255, 255, 255, 0.7);
      border: none;
      font-weight: 500;
      font-size: 0.95rem;
      padding: 0.5rem 1.2rem;
      border-radius: 50px;
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s ease;
    }

    .btn-welcome-ghost:hover {
      color: #ffffff;
    }

    .footer-note {
      margin-top: 3rem;
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.4);
    }
  </style>
</head>

<body>
  <div class="welcome-page">
    <div class="welcome-card">

      <div class="brand-icon">
        <i class="bi bi-globe2"></i>
      </div>

      <div class="brand-name">Wanderlust</div>

      <div class="divider"></div>

      <p class="brand-tagline">
        From cozy mountain homestays to beachside retreats — discover handpicked stays
        that feel like home, wherever in the world you wander.
      </p>

      <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center align-items-center">
        <a href="/register" class="btn btn-welcome-primary">
          <i class="bi bi-person-plus-fill me-1"></i> Sign Up
        </a>
        <a href="/login" class="btn btn-welcome-outline">
          <i class="bi bi-box-arrow-in-right me-1"></i> Login
        </a>
      </div>

      <div class="mt-3">
        <a href="/auth/google" class="btn btn-welcome-google">
          <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="18" height="18" alt="Google" />
          Continue with Google
        </a>
      </div>

      <div class="mt-2">
        <a href="/listings" class="btn btn-welcome-ghost">
          Browse as Guest &rarr;
        </a>
      </div>

      <div class="footer-note">
        &copy; 2026 Wanderlust &mdash; Find your perfect stay.
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>